@echo off
chcp 65001 >/dev/null
setlocal

echo.
echo ========================================
echo   Yazilim Ofisi - Tek Dosyalik Kurulum
echo ========================================
echo   10 ajan + 19 komut (Agile + Memory + Devral)
echo ========================================
echo.
set /p "ONAY=Bu klasore kurulsun mu? (e/h): "
if /i not "%ONAY%"=="e" (
    echo Iptal edildi.
    pause
    exit /b 0
)

set "TMPB64=%TEMP%\yo-%RANDOM%.b64"
set "TMPZIP=%TEMP%\yo-%RANDOM%.zip"
if exist "%TMPB64%" del "%TMPB64%"
>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 

echo Aciliyor...
powershell -NoProfile -Command "$b64 = (Get-Content '%TMPB64%' -Raw) -replace '\s',''; [IO.File]::WriteAllBytes('%TMPZIP%', [Convert]::FromBase64String($b64)); Expand-Archive '%TMPZIP%' -DestinationPath '%CD%' -Force"

if errorlevel 1 (
    echo HATA.
    if exist "%TMPB64%" del "%TMPB64%"
    if exist "%TMPZIP%" del "%TMPZIP%"
    pause
    exit /b 1
)
if exist "%TMPB64%" del "%TMPB64%"
if exist "%TMPZIP%" del "%TMPZIP%"

echo.
echo ========================================
echo   Tamam!
echo ========================================
echo.
echo Mevcut bir projede miyim?
echo   - context.md, .cursorrules vb. varsa: /devral
echo   - Sifirdan basliyorsam: /basla
echo.
echo Komutlar: /devral /basla /yardim /fikir /analiz /mimari
echo           /hikaye-olustur /backlog /sprint-plan /standup /retro
echo           /hikaye-gelistir /kod-inceleme /qa-plan
echo           /hata-raporu /hata-duzelt /danisma /memory /surum-kontrol
echo.
pause
