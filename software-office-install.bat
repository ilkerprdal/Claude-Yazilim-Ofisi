@echo off
chcp 65001 >/dev/null
setlocal

echo.
echo ========================================
echo   Software Office - Single-File Installer
echo ========================================
echo   10 agents + 19 commands
echo ========================================
echo.
echo This .bat installs .claude/, CLAUDE.md, README.md
echo and production/ into the current folder.
echo.
set /p "OK=Install into this folder? (y/n): "
if /i not "%OK%"=="y" if /i not "%OK%"=="e" (
    echo Cancelled.
    pause
    exit /b 0
)

set "TMPB64=%TEMP%\so-%RANDOM%.b64"
set "TMPZIP=%TEMP%\so-%RANDOM%.zip"
if exist "%TMPB64%" del "%TMPB64%"
>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 
>>"%TMPB64%" echo 

echo Extracting...
powershell -NoProfile -Command "$b64 = (Get-Content '%TMPB64%' -Raw) -replace '\s',''; [IO.File]::WriteAllBytes('%TMPZIP%', [Convert]::FromBase64String($b64)); Expand-Archive '%TMPZIP%' -DestinationPath '%CD%' -Force"

if errorlevel 1 (
    echo ERROR.
    if exist "%TMPB64%" del "%TMPB64%"
    if exist "%TMPZIP%" del "%TMPZIP%"
    pause
    exit /b 1
)
if exist "%TMPB64%" del "%TMPB64%"
if exist "%TMPZIP%" del "%TMPZIP%"

echo.
echo ========================================
echo   Done!
echo ========================================
echo.
echo Existing project with prior AI context?
echo   - context.md, .cursorrules, etc. present: /takeover
echo   - Starting fresh: /start
echo.
echo Tip: agents auto-detect your language.
echo.
pause
